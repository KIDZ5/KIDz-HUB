    local function fireSkill(fruitName, skillName, targetPos, delayTime)
        local remote = getRemote()
        if not remote then return end

        task.spawn(function()
            pcall(function()
                local char = getMyCharacter()
                local root = char and char:FindFirstChild("HumanoidRootPart")
                if not root then return end

                local originV3 = root.Position
                local targetV3 = targetPos or (originV3 + root.CFrame.LookVector * 100)
                local directionV3 = (targetV3 - originV3).Unit
                local lookAtCF = targetPos and CFrame.lookAt(originV3, targetV3) or root.CFrame

                local function toNativeVector(v3)
                    if vector and vector.create then 
                        return vector.create(v3.X, v3.Y, v3.Z) 
                    end
                    return v3
                end

                local fakeMousePayload = {
                    RootCF = lookAtCF, 
                    CF = lookAtCF, 
                    CFrame = lookAtCF,
                    Position = toNativeVector(targetV3), 
                    Target = toNativeVector(targetV3), 
                    Hit = CFrame.new(targetV3),
                    MouseRay = {
                        Normal = toNativeVector(Vector3.new(0, 1, 0)),
                        Direction = toNativeVector(directionV3 * 1000), 
                        Origin = toNativeVector(originV3),
                        Position = toNativeVector(targetV3),
                        Distance = (targetV3 - originV3).Magnitude,
                        Material = Enum.Material.Air,
                        Instance = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChildWhichIsA("BasePart") or nil
                    }
                }

                if remote:IsA("RemoteEvent") then 
                    remote:FireServer(fruitName, skillName, {MouseRay = fakeMousePayload.MouseRay})
                elseif remote:IsA("RemoteFunction") then 
                    task.spawn(function() 
                        remote:InvokeServer(fruitName, skillName, {MouseRay = fakeMousePayload.MouseRay}) 
                    end) 
                end

                local isHold = false
                local holdDuration = delayTime or 1.0

                pcall(function()
                    for _, parent in ipairs({lp:FindFirstChild("Backpack"), char}) do
                        if parent then
                            for _, tool in ipairs(parent:GetChildren()) do
                                local tName = tool:GetAttribute("Name") or tool:GetAttribute("SkillName") or tool.Name
                                if type(tName) == "string" and string.gsub(tName, "%s+", "") == skillName then
                                    local ht = tool:GetAttribute("HoldTime") or tool:GetAttribute("MaxHold") or tool:GetAttribute("Duration") or tool:GetAttribute("ChargeTime")
                                    if type(ht) == "number" and ht > 0 then
                                        isHold = true 
                                        holdDuration = ht
                                    elseif tool:GetAttribute("Hold") == true or tool:GetAttribute("IsHold") == true then
                                        isHold = true 
                                        if holdDuration == 0 then holdDuration = 1.0 end
                                    end
                                end
                            end
                        end
                    end
                end)

                if isHold then
                    _G.kidzIsHoldingSkill = true 
                    task.wait(0.2)
                    root = char:FindFirstChild("HumanoidRootPart")
                    if not root then 
                        _G.kidzIsHoldingSkill = false 
                        return 
                    end
                    
                    local updateLookCF = targetPos and CFrame.lookAt(root.Position, targetV3) or root.CFrame
                    local payloadUpdate = { 
                        RootCF = updateLookCF, 
                        MouseRay = fakeMousePayload.MouseRay 
                    }

                    if remote:IsA("RemoteEvent") then
                        remote:FireServer("ClientData", "UpdateData", payloadUpdate)
                        task.wait(holdDuration - 0.2)
                        remote:FireServer("ClientData", "ClearData", {})
                    elseif remote:IsA("RemoteFunction") then
                        task.spawn(function() remote:InvokeServer("ClientData", "UpdateData", payloadUpdate) end)
                        task.wait(holdDuration - 0.2)
                        task.spawn(function() remote:InvokeServer("ClientData", "ClearData", {}) end)
                    end
                    _G.kidzIsHoldingSkill = false 
                else
                    if remote:IsA("RemoteEvent") then 
                        remote:FireServer(fruitName, skillName, fakeMousePayload)
                    elseif remote:IsA("RemoteFunction") then 
                        task.spawn(function() remote:InvokeServer(fruitName, skillName, fakeMousePayload) end) 
                    end
                end
            end)
        end)
    end

