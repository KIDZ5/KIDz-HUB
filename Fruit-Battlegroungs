        local function timeToSeconds(timeStr)
            if not timeStr then return nil end
            local h, m, s = string.match(timeStr, "(%d+):(%d+):(%d+)")
            if h and m and s then return tonumber(h) * 3600 + tonumber(m) * 60 + tonumber(s) end
            local m2, s2 = string.match(timeStr, "(%d+):(%d+)")
            if m2 and s2 then return tonumber(m2) * 60 + tonumber(s2) end
            return nil
        end

        local function getServerTimeSec()
            local gui = lp:FindFirstChild("PlayerGui")
            local ui = gui and gui:FindFirstChild("UI")
            local info = ui and ui:FindFirstChild("Info")
